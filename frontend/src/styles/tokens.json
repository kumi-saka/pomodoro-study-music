{
  "colors": {
    "background": {
      "primary": "#121212",
      "secondary": "#2a2a2a",
      "tertiary": "rgba(0, 0, 0, 0.3)",
      "overlay": "rgba(255, 255, 255, 0.1)"
    },
    "text": {
      "primary": "#ffffff",
      "secondary": "rgba(255, 255, 255, 0.6)",
      "tertiary": "rgba(255, 255, 255, 0.5)",
      "inverse": "#000000"
    },
    "button": {
      "primary": {
        "bg": "#ffffff",
        "text": "#000000",
        "hover": "#f0f0f0"
      },
      "secondary": {
        "bg": "transparent",
        "text": "#ffffff",
        "border": "#404040",
        "hover": "rgba(255, 255, 255, 0.1)"
      }
    },
    "border": {
      "primary": "#404040",
      "secondary": "#525252",
      "white": "#ffffff"
    }
  },
  "typography": {
    "fontFamily": {
      "primary": "-apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif",
      "heading": "'Inter', sans-serif",
      "logo": "'Comfortaa', cursive"
    },
    "fontSize": {
      "xs": "12px",
      "sm": "14px",
      "base": "16px",
      "lg": "18px",
      "xl": "28px",
      "2xl": "42px",
      "3xl": "55px",
      "4xl": "60px",
      "5xl": "80px"
    },
    "fontWeight": {
      "light": 300,
      "normal": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    }
  },
  "spacing": {
    "xs": "4px",
    "sm": "6px",
    "md": "12px",
    "lg": "16px",
    "xl": "20px",
    "2xl": "24px",
    "3xl": "30px",
    "4xl": "35px"
  },
  "borderRadius": {
    "sm": "8px",
    "md": "10px",
    "lg": "12px",
    "xl": "50px",
    "full": "50px"
  },
  "shadows": {
    "sm": "0 0 2px rgba(255, 255, 255, 0.6)",
    "md": "0 4px 12px rgba(255, 255, 255, 0.2)",
    "text": "0 0 20px rgba(255, 255, 255, 0.3)"
  },
  "transitions": {
    "fast": "0.2s",
    "base": "0.3s",
    "slow": "0.5s"
  },
  "zIndex": {
    "header": 1000
  },
  "layout": {
    "headerHeight": "50px",
    "containerMaxWidth": "1200px"
